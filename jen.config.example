# Jen - The Internet Management Console
# Version 2.0 Configuration File
#
# Copy this file to /etc/jen/jen.config and fill in your values.
# This file is gitignored — never commit jen.config with real credentials.

[kea]
# Kea Control Agent REST API
api_url  = http://YOUR-KEA-SERVER:8000
api_user = kea-api
api_pass = your-kea-api-password

[kea_db]
# Kea MySQL database
host     = YOUR-KEA-SERVER
user     = kea
password = your-kea-db-password
database = kea

[jen_db]
# Jen MySQL database (separate from Kea)
host     = YOUR-DB-SERVER
user     = jen
password = your-jen-db-password
database = jen

[server]
http_port  = 5050
https_port = 8443

[kea_ssh]
# SSH connection to Kea server for subnet editing
# Leave host blank to disable subnet editing
host     = YOUR-KEA-SERVER
user     = your-ssh-user
key_path = /etc/jen/ssh/jen_rsa
kea_conf = /etc/kea/kea-dhcp4.conf

[subnets]
# Format: subnet_id = Friendly Name, CIDR
# Example:
# 1  = Production, 192.168.1.0/24
# 30 = IoT, 192.168.30.0/24
# 70 = VLAN70, 192.168.70.0/24

[ddns]
# Technitium DDNS integration
log_path    = /var/log/kea/kea-ddns-technitium.log
api_url     = https://your-technitium-server/api
api_token   = your-technitium-api-token
forward_zone = your.domain.com
