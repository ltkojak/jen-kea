# Jen - Docker Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values.
# These can replace a mounted jen.config entirely — if JEN_KEA_API_URL is set,
# Jen generates its config file automatically on first start.
#
# Alternatively, mount your own jen.config:
#   volumes:
#     - ./jen.config:/etc/jen/jen.config:ro
# ─────────────────────────────────────────────────────────────────────────────

# ── Kea Control Agent API (required) ─────────────────────────────────────────
JEN_KEA_API_URL=http://YOUR-KEA-SERVER:8000
JEN_KEA_API_USER=kea-api
JEN_KEA_API_PASS=your-kea-api-password
JEN_KEA_NAME=Kea Server 1
JEN_KEA_ROLE=primary
# HA mode: hot-standby | load-balancing | passive-backup | (leave blank)
JEN_HA_MODE=

# ── Kea MySQL Database (required) ────────────────────────────────────────────
JEN_KEA_DB_HOST=YOUR-KEA-SERVER
JEN_KEA_DB_USER=kea
JEN_KEA_DB_PASS=your-kea-db-password
JEN_KEA_DB_NAME=kea

# ── Jen MySQL Database (required) ────────────────────────────────────────────
# When using docker-compose.mysql.yml, set JEN_DB_HOST=jen-mysql
JEN_DB_HOST=YOUR-DB-SERVER
JEN_DB_USER=jen
JEN_DB_PASS=your-jen-db-password
JEN_DB_NAME=jen

# ── Server Ports ──────────────────────────────────────────────────────────────
JEN_HTTP_PORT=5050
JEN_HTTPS_PORT=8443

# ── SSH to Kea Server (optional — enables subnet editing from the UI) ─────────
JEN_KEA_SSH_HOST=YOUR-KEA-SERVER
JEN_KEA_SSH_USER=your-ssh-user
JEN_KEA_CONF=/etc/kea/kea-dhcp4.conf

# ── DDNS Integration (optional) ───────────────────────────────────────────────
# Provider: technitium | pihole | adguard | ssh | none
JEN_DDNS_PROVIDER=none
JEN_DDNS_URL=
JEN_DDNS_TOKEN=
JEN_DDNS_ZONE=your.domain.com
JEN_DDNS_LOG=/var/log/kea/kea-ddns.log

# ── Subnet Map (optional) ─────────────────────────────────────────────────────
# Format: id=Name,CIDR separated by semicolons
# Example: JEN_SUBNETS=1=Production,10.10.10.0/24;30=IoT,10.10.30.0/24
JEN_SUBNETS=

# ── Bundled MySQL (only used with docker-compose.mysql.yml) ──────────────────
MYSQL_ROOT_PASSWORD=changeme_root
JEN_MYSQL_PASSWORD=changeme_jen

# ── Host port mappings ────────────────────────────────────────────────────────
# These map host ports to container ports (host:container)
HTTP_PORT=5050
HTTPS_PORT=8443
